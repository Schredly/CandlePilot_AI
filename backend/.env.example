# Copy to .env and fill in. All values are optional during CP-001 —
# the service boots without a database or market-data provider, and every
# feature that needs one will fail loudly rather than silently.

ENVIRONMENT=dev

# Origins allowed to call the API. Comma-separated. Include your Next.js dev URL.
FRONTEND_ORIGINS=http://localhost:3000

# Postgres (future — CP-008+). Async driver: postgresql+asyncpg://
DATABASE_URL=

# Market data feed (future — CP-008). Provider is one of: alpaca, polygon, finnhub.
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=
MARKET_DATA_API_SECRET=

# Logging — DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
