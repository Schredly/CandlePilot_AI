# Root-level reference of every environment variable across the monorepo.
# Do NOT load this at the root — each service reads its own file:
#
#   backend/.env       (loaded by pydantic-settings)
#   frontend/.env.local (loaded by Next.js)
#
# See backend/.env.example and frontend/.env.example for authoritative,
# service-specific defaults. This file exists so a new contributor can
# see the full variable inventory in one place.

# ── backend ───────────────────────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
FRONTEND_ORIGINS=http://localhost:3000
DATABASE_URL=                              # postgresql+asyncpg://user:pass@host:5432/db
MARKET_DATA_PROVIDER=                      # alpaca | polygon | finnhub
MARKET_DATA_API_KEY=
MARKET_DATA_API_SECRET=

# ── frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
